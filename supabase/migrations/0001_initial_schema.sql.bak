  whatsapp_access_token,
  whatsapp_business_account_id,
  business_hours_start,
  business_hours_end,
  timezone,
  reminder_1_hours,
  reminder_2_hours
) values (
  'Cakewalk',
  'cakewalk',
  'REPLACE_WITH_PHONE_NUMBER_ID',
  null,
  'REPLACE_WITH_WABA_ID',
  9,
